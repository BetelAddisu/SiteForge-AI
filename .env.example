# =============================================================================
# SiteForge AI - Environment Configuration
# =============================================================================

# Supabase (Auth & Database)
# Get these from your Supabase project dashboard: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cloudflare R2 (Template Storage)
# Get from: https://dash.cloudflare.com/ > R2 > Manage R2 API Tokens
R2_ENDPOINT=https://[account-id].r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=siteforge-templates

# Prisma (Application Database)
# Direct connection to Supabase Postgres (use the Connection string from Supabase)
# Note: This connects to the same Supabase Postgres instance but through Prisma
# Pooled connection (via Supabase's PgBouncer, port 6543) - used for all app queries
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT].supabase.co:6543/postgres?pgbouncer=true&schema=siteforge"
# Direct connection (port 5432) - used only for migrations
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT].supabase.co:5432/postgres?schema=siteforge"

# Gemini AI (Content Generation)
# Get from: https://aistudio.google.com/
GEMINI_API_KEY=your-gemini-api-key

# Unsplash (Stock Images)
# Get from: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your-unsplash-access-key

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000

# Encryption (for WordPress password storage)
ENCRYPTION_KEY=your-random-32-character-string

# Optional: WordPress Connection (for Phase 13)
# WP_APPLICATION_PASSWORD_NAME=user
# WP_APPLICATION_PASSWORD=app-password-generated-in-wordpress

# Optional: External Services
# REDIS_URL=redis://localhost:6379
